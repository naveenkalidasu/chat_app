<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Chat - Tinglish Support</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .chat-container {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            width: 90%;
            max-width: 800px;
            height: 90vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
        }

        .chat-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: relative;
            z-index: 10;
        }

        .chat-header h2 {
            font-size: 1.2rem;
        }

        .header-controls {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .user-count {
            background: rgba(255,255,255,0.2);
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
            background: #f5f5f5;
            transition: background 0.3s ease;
        }

        /* Chat Area Themes */
        .chat-messages.theme-light { background: #f5f5f5; }
        .chat-messages.theme-dark { background: #1a1a1a; }
        .chat-messages.theme-blue { background: #e3f2fd; }
        .chat-messages.theme-green { background: #e8f5e9; }
        .chat-messages.theme-purple { background: #f3e5f5; }
        .chat-messages.theme-orange { background: #fff3e0; }
        .chat-messages.theme-pink { background: #fce4ec; }
        .chat-messages.theme-gray { background: #fafafa; }

        .chat-messages.theme-dark .message-other .message-content {
            background: #2d2d2d;
            color: #e0e0e0;
            box-shadow: 0 2px 5px rgba(0,0,0,0.3);
        }

        .chat-messages.theme-dark .message-own .message-content {
            background: #4a4a4a;
        }

        .chat-messages.theme-dark .message-username {
            color: #999;
        }

        .chat-messages.theme-dark .message-time {
            color: #666;
        }

        .message {
            margin-bottom: 15px;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .message-content {
            display: inline-block;
            max-width: 70%;
            padding: 12px 16px;
            border-radius: 12px;
            position: relative;
            word-wrap: break-word;
        }

        .message-own {
            text-align: right;
        }

        .message-own .message-content {
            background: #667eea;
            color: white;
            border-bottom-right-radius: 4px;
        }

        .message-other .message-content {
            background: white;
            color: #333;
            border-bottom-left-radius: 4px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .message-username {
            font-size: 0.75rem;
            color: #666;
            margin-bottom: 4px;
            font-weight: 600;
        }

        .message-own .message-username {
            color: #999;
        }

        .message-time {
            font-size: 0.7rem;
            color: #999;
            margin-top: 4px;
        }

        .message-status {
            font-size: 0.6rem;
            margin-left: 5px;
        }

        .message-ai-badge {
            font-size: 0.6rem;
            background: #667eea;
            color: white;
            padding: 2px 8px;
            border-radius: 10px;
            margin-left: 5px;
        }

        .typing-indicator {
            padding: 10px 20px;
            font-style: italic;
            color: #666;
            font-size: 0.9rem;
            background: white;
            transition: opacity 0.3s;
            border-top: 1px solid #eee;
        }

        .typing-indicator span {
            animation: typingDot 1.4s infinite;
            display: inline-block;
        }

        @keyframes typingDot {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-10px); }
        }

        .chat-input-container {
            position: relative;
            padding: 20px;
            background: white;
            border-top: 1px solid #eee;
        }

        .chat-input {
            display: flex;
            gap: 10px;
        }

        .chat-input input {
            flex: 1;
            padding: 12px 15px;
            border: 2px solid #eee;
            border-radius: 25px;
            outline: none;
            font-size: 1rem;
            transition: border-color 0.3s;
        }

        .chat-input input:focus {
            border-color: #667eea;
        }

        .chat-input button {
            padding: 12px 25px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 25px;
            cursor: pointer;
            font-size: 1rem;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .chat-input button:hover {
            transform: scale(1.05);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        /* Tinglish Suggestions Dropdown */
        .suggestions-container {
            position: absolute;
            bottom: 80px;
            left: 20px;
            right: 20px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            max-height: 200px;
            overflow-y: auto;
            display: none;
            z-index: 100;
        }

        .suggestions-container.show {
            display: block;
        }

        .suggestion-item {
            padding: 10px 15px;
            cursor: pointer;
            transition: background 0.2s;
            border-bottom: 1px solid #f0f0f0;
        }

        .suggestion-item:hover {
            background: #f0f0f0;
        }

        .suggestion-item:last-child {
            border-bottom: none;
        }

        .suggestion-text {
            font-weight: 500;
            color: #333;
        }

        .suggestion-meaning {
            font-size: 0.8rem;
            color: #666;
            margin-top: 2px;
        }

        .suggestion-badge {
            font-size: 0.6rem;
            background: #667eea;
            color: white;
            padding: 1px 6px;
            border-radius: 8px;
            margin-left: 8px;
        }

        /* AI Features */
        .ai-features {
            display: flex;
            gap: 5px;
            padding: 8px 20px;
            background: #f8f9fa;
            border-top: 1px solid #eee;
            flex-wrap: wrap;
        }

        .ai-button {
            padding: 6px 12px;
            border: none;
            border-radius: 15px;
            background: #e9ecef;
            color: #495057;
            cursor: pointer;
            font-size: 0.75rem;
            transition: all 0.3s;
        }

        .ai-button:hover {
            background: #667eea;
            color: white;
            transform: translateY(-2px);
        }

        .ai-button.active {
            background: #667eea;
            color: white;
        }

        /* Theme Picker */
        .theme-picker {
            display: none;
            position: absolute;
            top: 60px;
            right: 10px;
            background: white;
            border-radius: 12px;
            padding: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            z-index: 100;
            width: 200px;
        }

        .theme-picker.show {
            display: block;
        }

        .theme-picker h4 {
            margin-bottom: 10px;
            color: #333;
            font-size: 0.9rem;
        }

        .theme-options {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
        }

        .theme-option {
            padding: 8px 4px;
            border-radius: 8px;
            border: 2px solid transparent;
            cursor: pointer;
            transition: all 0.3s;
            text-align: center;
            font-size: 0.7rem;
            color: #333;
            background: #f5f5f5;
        }

        .theme-option:hover {
            transform: scale(1.05);
        }

        .theme-option.active {
            border-color: #667eea;
            box-shadow: 0 0 0 2px #667eea;
        }

        .theme-option.preview-light { background: #f5f5f5; }
        .theme-option.preview-dark { background: #1a1a1a; color: white; }
        .theme-option.preview-blue { background: #e3f2fd; }
        .theme-option.preview-green { background: #e8f5e9; }
        .theme-option.preview-purple { background: #f3e5f5; }
        .theme-option.preview-orange { background: #fff3e0; }
        .theme-option.preview-pink { background: #fce4ec; }
        .theme-option.preview-gray { background: #fafafa; }

        @media (max-width: 600px) {
            .chat-container {
                width: 100%;
                height: 100vh;
                border-radius: 0;
            }
            
            .message-content {
                max-width: 85%;
            }
            
            .theme-picker {
                width: 160px;
                right: 5px;
            }
            
            .suggestions-container {
                bottom: 70px;
                left: 10px;
                right: 10px;
            }
        }
    </style>
</head>
<body>
    <div class="chat-container">
        <div class="chat-header">
            <h2>💬 AI Chat - Tinglish</h2>
            <div class="header-controls">
                <div class="user-count">👥 <span id="userCount">1</span></div>
                <button class="theme-toggle" onclick="toggleThemePicker()">🎨 Theme</button>
            </div>
        </div>
        
        <!-- Theme Picker -->
        <div class="theme-picker" id="themePicker">
            <h4>Chat Theme</h4>
            <div class="theme-options">
                <div class="theme-option preview-light active" onclick="changeChatTheme('light')">Light</div>
                <div class="theme-option preview-dark" onclick="changeChatTheme('dark')">Dark</div>
                <div class="theme-option preview-blue" onclick="changeChatTheme('blue')">Blue</div>
                <div class="theme-option preview-green" onclick="changeChatTheme('green')">Green</div>
                <div class="theme-option preview-purple" onclick="changeChatTheme('purple')">Purple</div>
                <div class="theme-option preview-orange" onclick="changeChatTheme('orange')">Orange</div>
                <div class="theme-option preview-pink" onclick="changeChatTheme('pink')">Pink</div>
                <div class="theme-option preview-gray" onclick="changeChatTheme('gray')">Gray</div>
            </div>
        </div>
        
        <div class="chat-messages theme-light" id="messages"></div>
        
        <div class="typing-indicator" id="typingIndicator" style="display: none;">
            <span>Someone is typing</span><span>.</span><span>.</span><span>.</span>
        </div>
        
        <div class="ai-features">
            <button class="ai-button" onclick="toggleGrammar()">📝 Grammar Check</button>
            <button class="ai-button" style="background: #667eea; color: white;">🔤 Tinglish Support</button>
        </div>
        
        <div class="chat-input-container">
            <div class="suggestions-container" id="suggestionsContainer"></div>
            
            <div class="chat-input">
                <input type="text" id="messageInput" placeholder="Type in English or Tinglish..." />
                <button onclick="sendMessage()">Send</button>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const username = '<%= username %>';
        let grammarEnabled = false;
        let suggestionTimeout = null;

        socket.emit('join', username);

        // Send message on Enter key
        document.getElementById('messageInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                sendMessage();
            }
        });

        // Tinglish auto-suggestions
        document.getElementById('messageInput').addEventListener('input', (e) => {
            const input = e.target.value.trim();
            
            clearTimeout(suggestionTimeout);
            
            if (input.length >= 2) {
                suggestionTimeout = setTimeout(() => {
                    socket.emit('getSuggestions', input);
                }, 300);
            } else {
                document.getElementById('suggestionsContainer').classList.remove('show');
            }
        });

        // Typing indicator
        let typingTimeout;
        document.getElementById('messageInput').addEventListener('input', () => {
            socket.emit('typing', true);
            clearTimeout(typingTimeout);
            typingTimeout = setTimeout(() => {
                socket.emit('typing', false);
            }, 2000);
        });

        function sendMessage() {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            
            if (message) {
                if (grammarEnabled && !message.startsWith('/')) {
                    socket.emit('chatMessage', '/correct ' + message);
                } else {
                    socket.emit('chatMessage', message);
                }
                input.value = '';
                document.getElementById('suggestionsContainer').classList.remove('show');
            }
        }

        // Receive suggestions
        socket.on('suggestions', (suggestions) => {
            const container = document.getElementById('suggestionsContainer');
            container.innerHTML = '';
            
            if (suggestions.length === 0) {
                container.classList.remove('show');
                return;
            }
            
            suggestions.forEach(suggestion => {
                const item = document.createElement('div');
                item.className = 'suggestion-item';
                
                const textDiv = document.createElement('div');
                textDiv.className = 'suggestion-text';
                textDiv.textContent = suggestion.text;
                
                if (suggestion.isPattern) {
                    const badge = document.createElement('span');
                    badge.className = 'suggestion-badge';
                    badge.textContent = 'Common';
                    textDiv.appendChild(badge);
                }
                
                const meaningDiv = document.createElement('div');
                meaningDiv.className = 'suggestion-meaning';
                meaningDiv.textContent = suggestion.meaning || 'Tinglish phrase';
                
                item.appendChild(textDiv);
                item.appendChild(meaningDiv);
                
                item.onclick = () => {
                    document.getElementById('messageInput').value = suggestion.text;
                    container.classList.remove('show');
                    document.getElementById('messageInput').focus();
                };
                
                container.appendChild(item);
            });
            
            container.classList.add('show');
        });

        socket.on('messageHistory', (messages) => {
            const messagesDiv = document.getElementById('messages');
            messagesDiv.innerHTML = '';
            messages.forEach(msg => addMessage(msg));
            scrollToBottom();
        });

        socket.on('chatMessage', (data) => {
            addMessage(data);
            scrollToBottom();
        });

        function addMessage(data) {
            const messagesDiv = document.getElementById('messages');
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${data.userId === socket.id ? 'message-own' : 'message-other'}`;
            
            const time = new Date(data.timestamp).toLocaleTimeString();
            const status = data.status === 'seen' ? '✓✓' : data.status === 'delivered' ? '✓✓' : '✓';
            
            let aiBadge = '';
            if (data.isAIGenerated) {
                aiBadge = `<span class="message-ai-badge">📝 Grammar</span>`;
            }

            messageDiv.innerHTML = `
                <div class="message-username">${data.username} ${aiBadge}</div>
                <div class="message-content">${data.msg}</div>
                <div class="message-time">
                    ${time}
                    ${data.userId === socket.id ? `<span class="message-status">${status}</span>` : ''}
                </div>
            `;
            
            messagesDiv.appendChild(messageDiv);
        }

        socket.on('userJoined', (username) => {
            const messagesDiv = document.getElementById('messages');
            const systemMsg = document.createElement('div');
            systemMsg.className = 'message message-other';
            systemMsg.innerHTML = `<div class="message-content" style="background: #e9ecef; color: #666; text-align: center;">👋 ${username} joined the chat</div>`;
            messagesDiv.appendChild(systemMsg);
            scrollToBottom();
        });

        socket.on('userLeft', (username) => {
            const messagesDiv = document.getElementById('messages');
            const systemMsg = document.createElement('div');
            systemMsg.className = 'message message-other';
            systemMsg.innerHTML = `<div class="message-content" style="background: #e9ecef; color: #666; text-align: center;">👋 ${username} left the chat</div>`;
            messagesDiv.appendChild(systemMsg);
            scrollToBottom();
        });

        socket.on('updateUserCount', (count) => {
            document.getElementById('userCount').textContent = count;
        });

        socket.on('userTyping', (data) => {
            const indicator = document.getElementById('typingIndicator');
            if (data.isTyping && data.userId !== socket.id) {
                indicator.innerHTML = `<span>${data.username} is typing</span><span>.</span><span>.</span><span>.</span>`;
                indicator.style.display = 'block';
            } else {
                indicator.style.display = 'none';
            }
        });

        socket.on('messageStatusUpdate', (data) => {
            const messages = document.querySelectorAll('.message');
            messages.forEach(msg => {
                const timeElement = msg.querySelector('.message-time');
                if (timeElement) {
                    const statusSpan = timeElement.querySelector('.message-status');
                    if (statusSpan) {
                        if (data.status === 'seen') {
                            statusSpan.textContent = '✓✓';
                        } else if (data.status === 'delivered') {
                            statusSpan.textContent = '✓✓';
                        }
                    }
                }
            });
        });

        function scrollToBottom() {
            const messagesDiv = document.getElementById('messages');
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        function toggleGrammar() {
            grammarEnabled = !grammarEnabled;
            const button = document.querySelector('[onclick="toggleGrammar()"]');
            if (grammarEnabled) {
                button.classList.add('active');
                button.textContent = '📝 Grammar ON';
            } else {
                button.classList.remove('active');
                button.textContent = '📝 Grammar Check';
            }
        }

        // Theme functions
        function toggleThemePicker() {
            const picker = document.getElementById('themePicker');
            picker.classList.toggle('show');
        }

        function changeChatTheme(theme) {
            const messagesDiv = document.getElementById('messages');
            messagesDiv.className = 'chat-messages';
            messagesDiv.classList.add('theme-' + theme);
            
            document.querySelectorAll('.theme-option').forEach(el => {
                el.classList.remove('active');
            });
            document.querySelector('.preview-' + theme).classList.add('active');
            
            document.getElementById('themePicker').classList.remove('show');
            localStorage.setItem('chatAreaTheme', theme);
        }

        // Load saved theme
        document.addEventListener('DOMContentLoaded', () => {
            const savedTheme = localStorage.getItem('chatAreaTheme');
            if (savedTheme) {
                changeChatTheme(savedTheme);
            }
        });

        // Close modals when clicking outside
        document.addEventListener('click', (e) => {
            const themePicker = document.getElementById('themePicker');
            const themeToggle = document.querySelector('.theme-toggle');
            const suggestionsContainer = document.getElementById('suggestionsContainer');
            const input = document.getElementById('messageInput');
            
            if (themePicker.classList.contains('show') && 
                !themePicker.contains(e.target) && 
                e.target !== themeToggle) {
                themePicker.classList.remove('show');
            }
            
            if (suggestionsContainer.classList.contains('show') && 
                !suggestionsContainer.contains(e.target) && 
                e.target !== input) {
                suggestionsContainer.classList.remove('show');
            }
        });

        // Close suggestions on scroll
        document.getElementById('messages').addEventListener('scroll', () => {
            document.getElementById('suggestionsContainer').classList.remove('show');
        });
    </script>
</body>
</html>